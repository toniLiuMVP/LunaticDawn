  "TECHNIC.ENC": [
    {
      "id": 0,
      "name": "他的劍術根本就不管用。"
    },
    {
      "id": 1,
      "name": "他的劍好像還不夠銳利。"
    },
    {
      "id": 2,
      "name": "已達到普通的劍法了。"
    },
    {
      "id": 3,
      "name": "碰上這傢伙的人真可憐。"
    },
    {
      "id": 4,
      "name": "嗯，看起來蠻有本事的。"
    },
    {
      "id": 5,
      "name": "斧頭耍得不怎麼樣。"
    },
    {
      "id": 6,
      "name": "身手大概還不錯吧！"
    },
    {
      "id": 7,
      "name": "唉呀！還不怎麼樣喔！"
    },
    {
      "id": 8,
      "name": "已是了不起的高手了。"
    },
    {
      "id": 9,
      "name": "用起斧頭像用刀子般容易。"
    },
    {
      "id": 10,
      "name": "棍法表現得該去撞牆。"
    },
    {
      "id": 11,
      "name": "用棍勉強抵擋得住敵人。"
    },
    {
      "id": 12,
      "name": "嘿！沒問題了吧！"
    },
    {
      "id": 13,
      "name": "真不想和這傢伙為敵。"
    },
    {
      "id": 14,
      "name": "敵人三兩下就會被殺了。"
    },
    {
      "id": 15,
      "name": "每一槍刺出往往刺空。"
    },
    {
      "id": 16,
      "name": "還要再多磨鍊。"
    },
    {
      "id": 17,
      "name": "嗯，當同伴還不錯啦！"
    },
    {
      "id": 18,
      "name": "敵人往往逃不開他的攻擊。"
    },
    {
      "id": 19,
      "name": "好像可以一擊必中。"
    },
    {
      "id": 20,
      "name": "目標不怎麼對得準。"
    },
    {
      "id": 21,
      "name": "僥倖的技術，沒什麼吧！"
    },
    {
      "id": 22,
      "name": "大致上都沒問題吧！"
    },
    {
      "id": 23,
      "name": "十次裡還會中個八次。"
    },
    {
      "id": 24,
      "name": "聽說在空中飛的蟲子也能擊落。"
    },
    {
      "id": 25,
      "name": "好像會打到自己人。"
    },
    {
      "id": 26,
      "name": "還可以把敵人撂倒。"
    },
    {
      "id": 27,
      "name": "還需要再接受訓練！"
    },
    {
      "id": 28,
      "name": "敵人已不堪一擊。"
    },
    {
      "id": 29,
      "name": "那傢伙已不需要武器了。"
    },
    {
      "id": 30,
      "name": "好像會射到同伴。"
    },
    {
      "id": 31,
      "name": "大致上還能使用投擲武器。"
    },
    {
      "id": 32,
      "name": "和敵人已不相上下！"
    },
    {
      "id": 33,
      "name": "您不會想和他為敵的。"
    },
    {
      "id": 34,
      "name": "不論從哪個方位都能命中要害。"
    },
    {
      "id": 35,
      "name": "迴避之前還先愣了一下。"
    },
    {
      "id": 36,
      "name": "應該還能躲得開攻擊。"
    },
    {
      "id": 37,
      "name": "閃避上沒問題了。"
    },
    {
      "id": 38,
      "name": "即使被弓箭射擊也能輕鬆閃開。"
    },
    {
      "id": 39,
      "name": "被十個人圍住也能脫險。"
    },
    {
      "id": 40,
      "name": "好像連自己佈的陷阱都解不開。"
    },
    {
      "id": 41,
      "name": "只要能發現陷阱就還能夠解除吧！"
    },
    {
      "id": 42,
      "name": "交給他應該沒問題了！"
    },
    {
      "id": 43,
      "name": "沒有不能偷的東西。"
    },
    {
      "id": 44,
      "name": "還沒檢查陷阱之前就知道怎麼解除了。"
    },
    {
      "id": 45,
      "name": "有他在，保証會睡眠不足。"
    },
    {
      "id": 46,
      "name": "哎，勉強可以安心睡覺。"
    },
    {
      "id": 47,
      "name": "長途旅行時就勉為其難相信他吧！"
    },
    {
      "id": 48,
      "name": "好像很會野營的樣子。"
    },
    {
      "id": 49,
      "name": "有他在，保證可以睡得很熟。"
    },
    {
      "id": 50,
      "name": "好像連吟唱法術都有問題。"
    },
    {
