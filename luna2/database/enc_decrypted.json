  "EXPLAIN.ENC": [
    {
      "id": 0,
      "name": "用一種微生物所釀的葡萄酒，它的價格是天文數字。"
    },
    {
      "id": 1,
      "name": "將玻璃融化加工做成的裝飾品。較玻璃本身的價值高出許多。"
    },
    {
      "id": 2,
      "name": "是該地最高級的特產品。產量非常稀少，價值愈來愈高。"
    },
    {
      "id": 3,
      "name": "描繪宗教價值觀的物品。許多以獨特的技術所繪製的物品都有很高的價值。"
    },
    {
      "id": 4,
      "name": "指示前往持有者的道路，能為擁有者帶來幸運。外表看起來只是一把銅製的鑰匙。"
    },
    {
      "id": 5,
      "name": "可掛在牆上的裝飾品，能為擁有者帶來榮耀。"
    },
    {
      "id": 6,
      "name": "用金或銀塑造的高級杯子。用這種杯子，不管喝什麼都覺得很可口，甚至喝到死都願意。"
    },
    {
      "id": 7,
      "name": "可以說是吃的財寶，乃調味料之王。各地王公貴族們極為喜愛的物品。"
    },
    {
      "id": 8,
      "name": "麻藥，像煙草一般吸食。吸食此品就會被一股不可言喻的安全感包圍。"
    },
    {
      "id": 9,
      "name": "用動物的毛編織而成的色彩豐富的織品。用於舖在起居室的床上。"
    },
    {
      "id": 10,
      "name": "將象牙加工製成的各式各樣之裝飾品。不過，由於獵捕大象是一件高難度的事情，因而更顯得價值非凡。"
    },
    {
      "id": 11,
      "name": "能讓擁有者看見夢的實現，但終究是夢罷了。不過，不知為何，卻做成青銅幣的形狀。"
    },
    {
      "id": 12,
      "name": "通稱傳閱簿，據說在這本簿子上題名的話，就會遇到許多幸運的事，但真相如何就不得而知了。"
    },
    {
      "id": 13,
      "name": "據說記載著絕招，不過實際上好像是記錄性交的過程，是一本禁書。"
    },
    {
      "id": 14,
      "name": "古老傳說中的一種藥，種類有各式各樣，可治百病，相當珍貴。"
    },
    {
      "id": 15,
      "name": "麻藥的一種，會上癮，產生視幻覺，其價格也有如幻覺般遙不可及。"
    },
    {
      "id": 16,
      "name": "觸感絕佳的高級布料，為貿易商爭相取得的物品。"
    },
    {
      "id": 17,
      "name": "體型略大的瓦陶壺，壺面用三種色調極美的顏料彩繪。"
    },
    {
      "id": 18,
      "name": "曾經一度死亡，後來轉世為鳳凰的最初降落之石板。"
    },
    {
      "id": 19,
      "name": "遠古的國王努達巴契的骨頭。能為擁有者帶有諸多幸運。"
    },
    {
      "id": 20,
      "name": "焚香用的容器，傳說中的傑作，容器表面永遠都是濕潤的狀態。"
    },
    {
      "id": 21,
      "name": "香菇的一種，不知為何只寄生於赤松等少數種類之樹木，一直是高價物品。"
    },
    {
      "id": 22,
      "name": "將煙草的葉片摘下烘乾，塞入煙斗裡吸食。有時會使人中毒。"
    },
    {
      "id": 23,
      "name": "用漆樹抽取出的染料上色的食器。上過漆的價錢漲好幾倍。"
    },
    {
      "id": 24,
      "name": "用玳瑁龜的甲殼做成的，具有斑紋的薄片，加工成裝飾品。"
    },
    {
      "id": 25,
      "name": "全部用黃金打造。據說擁有者能往神的所在去。"
    },
    {
      "id": 26,
      "name": "打造者嘔心瀝血琢磨而成的珠玉極品，琢磨過度的話，就只會映照出靈魂。"
    },
    {
      "id": 27,
      "name": "淡紅色的玉耳環。據說將它帶在耳朵上的話，任何細微的聲音都聽得到。"
    },
    {
      "id": 28,
      "name": "有滋養強壯的效果，因為採擷時必需要具備相當純熟的技術，所以價格昂貴。"
    },
    {
      "id": 29,
      "name": "用某種植物經過某種製造過程製成的麻藥，像煙草一般吸食。"
    },
    {
      "id": 30,
      "name": "主要用於煉金術，對魔術師而言非常重要。採集量很少，因此非常昂貴。"
    },
    {
      "id": 31,
      "name": "將豹皮俐落地剝下，左右攤開做為墊子。坦白地說，貴得很。"
    },
    {
      "id": 32,
      "name": "與諸神共同生存的魚的魚鱗。據說能讓擁有者免於生病之苦。"
    },
    {
      "id": 33,
      "name": "長２公分，謎樣的觸角。據說若吞進腹肚，會在體內游走，驅除病原。"
    },
    {
      "id": 34,
      "name": "擊倒某位勇者的狼人身上所佩帶的物品。據說有可以使力量倍增，振奮精神的效果。"
    },
    {
      "id": 35,
      "name": "具有各種魔法要素的藥草。至於用途的話，總之不會是什麼好魔法。"
    },
    {
      "id": 36,
      "name": "魔法的解藥。不論中什麼樣的魔法都有效，特別是對付破壞最有名。"
    },
    {
      "id": 37,
      "name": "出產的地方不是秘密，但作法則很神秘，對所有的傷都有療效。"
    },
    {
      "id": 38,
      "name": "自古以來即存在的，可奏出相當優美旋律的弦樂器，有各式各樣的種類。"
    },
    {
      "id": 39,
      "name": "肉人的肉當中最美味的肝，數量極少，很難取得。"
    },
    {
      "id": 40,
      "name": "帶在身上的話，據說不管是多老的人，都可以回復年輕的軀體。創造者是個謎。"
    },
    {
      "id": 41,
      "name": "精神感應金屬，非常硬，加工也很困難。不過，能感應它的人，可輕而易舉地雕塑它。"
    }
